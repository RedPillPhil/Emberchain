{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Emberchain Desktop",
  "version": "0.1.0",
  "identifier": "org.emberchain.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Emberchain Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8545 https://emberchain.org; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../node-resources/server.mjs": "server.mjs"
    },
    "category": "Finance",
    "shortDescription": "Emberchain full-node desktop wallet",
    "longDescription": "A full-node wallet for the Emberchain (EMBR) network. Runs a local node, syncs the full chain, and stores keys securely on your machine.",
    "copyright": "© 2025 Emberchain",
    "linux": {
      "deb": { "depends": [] }
    },
    "windows": {
      "wix": {}
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
