{
  "name": "@workspace/emberchain-wallet-electron",
  "version": "2.0.0",
  "description": "Emberchain desktop wallet",
  "main": "main.js",
  "private": true,
  "author": {
    "name": "Emberchain",
    "email": "hello@emberchain.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RedPillPhil/Emberchain.git"
  },
  "dependencies": {
    "ethers": "^6.13.4",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "*"
  },
  "scripts": {
    "start": "electron .",
    "bundle-engine": "node scripts/bundle-node-engine.mjs",
    "dist:win": "node scripts/bundle-node-engine.mjs && electron-builder --win --publish never",
    "dist:mac": "node scripts/bundle-node-engine.mjs && electron-builder --mac --publish never",
    "dist:linux": "node scripts/bundle-node-engine.mjs && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "org.emberchain.desktop",
    "productName": "EmberChain Desktop",
    "copyright": "Copyright © 2025 Emberchain",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node-engine-bundle.cjs",
      "mining-worker.js",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "build/icon.icns",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "build/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
